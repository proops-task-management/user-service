PORT=8081
SPRING_DATASOURCE_URL=jdbc:mysql://db-user:3306/users_db
SPRING_DATASOURCE_USERNAME=app_user
SPRING_DATASOURCE_PASSWORD=app_pass
# RS256 signing (D6 — IRD-001 amended / ADR-005). PKCS#8 PEM private key; this service is the ONLY
# signer. api-gateway verifies with the public half (JWT_PUBLIC_KEYS). Locally:
# export JWT_PRIVATE_KEY="$(cat jwt-private-dev.pem)" (dev keypair, never committed).
JWT_PRIVATE_KEY=change_me_pkcs8_pem_single_line_with_\n_escaped_newlines
JWT_EXPIRES_IN=86400000

# MySQL container bootstrap (used by docker-compose.yml)
DB_USER_DATABASE=users_db
DB_USER_USER=app_user
DB_USER_PASSWORD=app_pass
DB_USER_ROOT_PASSWORD=change_me_root
